# Server Configuration
SERVER_ADDRESS=:8080
SERVER_PORT=8080

# Database Configuration
DB_HOST=localhost
DB_PORT=5432
DB_USER=postgres
DB_PASSWORD=your_password_here
DB_NAME=codecollab
DB_SSLMODE=disable

# Redis Configuration
REDIS_HOST=localhost
REDIS_PORT=6379
REDIS_PASSWORD=
REDIS_DB=0

# Storage Configuration
# Options: "local" or "s3"
STORAGE_TYPE=local
STORAGE_LOCAL_PATH=./workspaces

# S3 Configuration (if STORAGE_TYPE=s3)
STORAGE_S3_BUCKET=codecollab-workspaces
STORAGE_S3_REGION=us-east-1
STORAGE_S3_ENDPOINT=

# Security Configuration
JWT_SECRET=your_jwt_secret_here_change_in_production

# Logging
LOG_LEVEL=info
